generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model ErrorEntry {
  id              Int      @id @default(autoincrement())
  errorQuery      String   @unique
  whyItHappens    String
  howToAvoid      String
  solutionSteps   String
  command         String?
  youtubeCode     String?
  createdAt       DateTime @default(now())
}
